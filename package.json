{
  "name": "dbw-base",
  "version": "3.1.0",
  "description": "Ultra-lightweight GeneratePress child theme by dbw media",
  "type": "module",
  "scripts": {
    "tokens": "node scripts/generate-tokens.js",
    "predev": "node scripts/generate-tokens.js",
    "dev": "vite",
    "prebuild": "node scripts/generate-tokens.js",
    "build": "vite build",
    "build:watch": "node scripts/generate-tokens.js && vite build --watch",
    "preview": "vite preview",
    "blocks:build": "npm run build --prefix blocks",
    "blocks:start": "npm run start --prefix blocks",
    "build:all": "vite build && npm run build --prefix blocks"
  },
  "keywords": [
    "wordpress",
    "generatepress",
    "child-theme"
  ],
  "author": "dbw media <info@dbw-media.de>",
  "license": "GPL-2.0-or-later",
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "sass": "^1.83.4",
    "vite": "^6.0.11"
  },
  "browserslist": [
    "defaults",
    "not IE 11"
  ],
  "dependencies": {
    "lenis": "^1.3.17"
  }
}
