{
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "color": {
      "custom": false,
      "customGradient": false,
      "palette": [
        {
          "name": "Primär (Brand)",
          "slug": "primary",
          "color": "#526983"
        },
        {
          "name": "Sekundär",
          "slug": "secondary",
          "color": "#333333"
        },
        {
          "name": "Akzent",
          "slug": "accent",
          "color": "#526983"
        },
        {
          "name": "Highlight",
          "slug": "highlight",
          "color": "#333333"
        },
        {
          "name": "Hintergrund",
          "slug": "base-bg",
          "color": "#f9f8f6"
        },
        {
          "name": "Body Background",
          "slug": "body-bg",
          "color": "#f9f8f6"
        },
        {
          "name": "Dunkelgrau",
          "slug": "dark-grey",
          "color": "#1a1a1a"
        },
        {
          "name": "Weiß",
          "slug": "white",
          "color": "#ffffff"
        }
      ]
    },
    "spacing": {
      "customSpacingSize": false,
      "spacingSizes": [
        {
          "name": "Klein (S)",
          "slug": "s",
          "size": "clamp(1.5rem, 4vw, 2.5rem)"
        },
        {
          "name": "Mittel (M)",
          "slug": "m",
          "size": "clamp(3rem, 6vw, 5rem)"
        },
        {
          "name": "Groß (L)",
          "slug": "l",
          "size": "clamp(5rem, 10vw, 8rem)"
        }
      ]
    },
    "typography": {
      "customFontSize": false,
      "fontFamilies": [
        {
          "fontFamily": "\"Cormorant Garamond\", serif",
          "name": "Cormorant Garamond (Headings)",
          "slug": "serif-heading"
        },
        {
          "fontFamily": "\"DM Sans\", sans-serif",
          "name": "DM Sans (Body text)",
          "slug": "system-body"
        }
      ]
    },
    "layout": {
      "contentSize": "800px",
      "wideSize": "1200px"
    },
    "custom": {
      "dbw": {
        "colorsConfigured": true
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base-bg)",
      "text": "var(--wp--preset--color--dark-grey)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-body)"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--serif-heading)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      }
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": "4px"
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "#ffffff"
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--system-body)"
        }
      }
    }
  }
}
