{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "dbw-base/logo-grid",
  "version": "3.1.0",
  "title": "Logo-Grid",
  "category": "dbw-base",
  "icon": "images-alt2",
  "description": "Partner-Logo-Grid mit automatischem Graustufen-Filter und Hover-Effekt.",
  "keywords": ["logo", "partner", "kunden", "grid", "referenzen"],
  "textdomain": "dbw-base",
  "supports": {
    "align": ["wide", "full"],
    "html": false,
    "anchor": true
  },
  "attributes": {
    "anchor": { "type": "string", "default": "" },
    "align": {
      "type": "string",
      "default": "wide"
    },
    "logos": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object"
      }
    },
    "columns": {
      "type": "number",
      "default": 4
    },
    "paddingSize": {
      "type": "string",
      "default": "m",
      "enum": ["s", "m", "l"]
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}
