{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "dbw-base/section",
  "version": "3.1.0",
  "title": "Section",
  "category": "dbw-base",
  "icon": "align-wide",
  "description": "Äußerer Container für Sektionen mit Padding, Hintergrundfarbe und optionalem Background-Image.",
  "keywords": ["section", "container", "wrapper", "sektion"],
  "textdomain": "dbw-base",
  "supports": {
    "align": ["wide", "full"],
    "html": false,
    "anchor": true
  },
  "attributes": {
    "anchor": { "type": "string", "default": "" },
    "align": {
      "type": "string",
      "default": "full"
    },
    "paddingSize": {
      "type": "string",
      "default": "m",
      "enum": ["s", "m", "l"]
    },
    "backgroundColor": {
      "type": "string",
      "default": ""
    },
    "customBackgroundColor": {
      "type": "string",
      "default": ""
    },
    "contentAlign": {
      "type": "string",
      "default": "left"
    },
    "backgroundImageId": {
      "type": "number"
    },
    "backgroundImageUrl": {
      "type": "string"
    },
    "backgroundImageAlt": {
      "type": "string",
      "default": ""
    },
    "overlayOpacity": {
      "type": "number",
      "default": 50
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}
