{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "dbw-base/cards",
  "version": "3.1.0",
  "title": "Card Grid",
  "category": "dbw-base",
  "icon": "grid-view",
  "description": "Grid-Container für Karten. Steuert Spaltenanzahl (2, 3 oder 4).",
  "keywords": ["cards", "grid", "karten", "raster"],
  "textdomain": "dbw-base",
  "supports": {
    "align": ["wide", "full"],
    "html": false,
    "anchor": true
  },
  "attributes": {
    "anchor": { "type": "string", "default": "" },
    "align": {
      "type": "string",
      "default": "wide"
    },
    "columns": {
      "type": "number",
      "default": 3
    },
    "paddingSize": {
      "type": "string",
      "default": "m",
      "enum": ["s", "m", "l"]
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}
