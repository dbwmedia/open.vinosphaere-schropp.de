{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "dbw-base/usp-list",
  "version": "3.1.0",
  "title": "USP Icon-List",
  "category": "dbw-base",
  "icon": "yes-alt",
  "description": "Liste von Verkaufsargumenten mit vordefinierten Icons.",
  "keywords": ["usp", "icons", "liste", "vorteile", "features"],
  "textdomain": "dbw-base",
  "supports": {
    "align": ["wide", "full"],
    "html": false,
    "anchor": true
  },
  "attributes": {
    "anchor": { "type": "string", "default": "" },
    "align": {
      "type": "string",
      "default": "wide"
    },
    "columns": {
      "type": "number",
      "default": 3
    },
    "paddingSize": {
      "type": "string",
      "default": "m",
      "enum": ["s", "m", "l"]
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}
