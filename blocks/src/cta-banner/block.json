{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "dbw-base/cta-banner",
  "version": "3.1.0",
  "title": "CTA-Banner",
  "category": "dbw-base",
  "icon": "megaphone",
  "description": "High-Attention Conversion-Banner mit Headline und Call-to-Action Button.",
  "keywords": ["cta", "banner", "conversion", "call-to-action", "aktion"],
  "textdomain": "dbw-base",
  "supports": {
    "align": ["wide", "full"],
    "html": false,
    "anchor": true
  },
  "attributes": {
    "anchor": { "type": "string", "default": "" },
    "align": {
      "type": "string",
      "default": "full"
    },
    "heading": {
      "type": "string",
      "default": ""
    },
    "text": {
      "type": "string",
      "default": ""
    },
    "buttonText": {
      "type": "string",
      "default": ""
    },
    "buttonUrl": {
      "type": "string",
      "default": ""
    },
    "style": {
      "type": "string",
      "default": "primary",
      "enum": ["primary", "dark"]
    },
    "paddingSize": {
      "type": "string",
      "default": "m",
      "enum": ["s", "m", "l"]
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}
