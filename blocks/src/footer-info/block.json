{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "dbw-base/footer-info",
  "version": "3.1.0",
  "title": "Footer Info",
  "category": "dbw-base",
  "icon": "info-outline",
  "description": "Flexibler Footer-/Info-Block mit Logo, Firmeninformationen, Öffnungszeiten, rechtlichen Links und Scroll-to-Top.",
  "keywords": ["footer", "info", "impressum", "kontakt", "öffnungszeiten", "adresse"],
  "textdomain": "dbw-base",
  "supports": {
    "align": ["wide", "full"],
    "html": false,
    "anchor": true
  },
  "attributes": {
    "anchor":          { "type": "string", "default": "" },
    "align":           { "type": "string", "default": "full" },
    "paddingSize":           { "type": "string", "default": "m", "enum": ["s", "m", "l"] },
    "backgroundColor":       { "type": "string", "default": "dark-grey" },
    "customBackgroundColor": { "type": "string", "default": "" },
    "customTextColor":       { "type": "string", "default": "" },
    "customHeadingColor":    { "type": "string", "default": "" },
    "customSocialColor":     { "type": "string", "default": "" },
    "contentAlign":          { "type": "string", "default": "left" },

    "showLogo":  { "type": "boolean", "default": true },
    "logoId":    { "type": "number" },
    "logoUrl":   { "type": "string" },
    "logoAlt":   { "type": "string", "default": "" },
    "logoWidth": { "type": "number", "default": 160 },

    "showCompanyInfo": { "type": "boolean", "default": true },
    "companyName":     { "type": "string",  "default": "" },
    "companyAddress":  { "type": "string",  "default": "" },
    "companyExtra":    { "type": "string",  "default": "" },

    "showOpeningHours":  { "type": "boolean", "default": false },
    "openingHoursLabel": { "type": "string",  "default": "Öffnungszeiten" },
    "openingHoursText":  { "type": "string",  "default": "" },

    "showSecondaryImage":       { "type": "boolean", "default": false },
    "secondaryImageId":         { "type": "number" },
    "secondaryImageUrl":        { "type": "string" },
    "secondaryImageAlt":        { "type": "string", "default": "" },
    "secondaryImageLinkUrl":    { "type": "string", "default": "" },
    "secondaryImageLinkNewTab": { "type": "boolean", "default": false },
    "secondaryImageMaxWidth":   { "type": "number",  "default": 0 },

    "showDivider": { "type": "boolean", "default": true },

    "showImpressum":  { "type": "boolean", "default": false },
    "impressumUrl":   { "type": "string",  "default": "" },
    "showAgb":        { "type": "boolean", "default": false },
    "agbUrl":         { "type": "string",  "default": "" },
    "showDatenschutz": { "type": "boolean", "default": true },
    "datenschutzUrl": { "type": "string",  "default": "" },

    "showScrollTop":   { "type": "boolean", "default": true },
    "scrollTopAnchor": { "type": "string",  "default": "#top" },

    "stackedLayout":      { "type": "boolean", "default": false },

    "impressumNewTab":    { "type": "boolean", "default": false },
    "agbNewTab":          { "type": "boolean", "default": false },
    "datenschutzNewTab":  { "type": "boolean", "default": false },

    "showSocialLinks":  { "type": "boolean", "default": false },
    "socialIconStyle":  { "type": "string",  "default": "circle" },
    "socialLinks":      { "type": "array",   "default": [] }
  },
  "editorScript": "file:./index.js",
  "editorStyle":  "file:./index.css",
  "style":        "file:./style-index.css",
  "render":       "file:./render.php"
}
